@prefix vez:  <http://example.org/vezilka/ontology#> .
@prefix vezr: <http://example.org/vezilka/resource/> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# =============================================================
# Shape: Лексема
# =============================================================

vez:ЛексемаShape a sh:NodeShape ;
    sh:targetClass vez:Лексема ;
    sh:property [
        sh:path vez:wordForm ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "word form" ;
    ] ;
    sh:property [
        sh:path vez:appearsInDialect ;
        sh:minCount 1 ;
        sh:class vez:Дијалект ;
        sh:name "dialect attestation" ;
    ] ;
    sh:property [
        sh:path vez:frequency ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:name "corpus frequency" ;
    ] .

# =============================================================
# Shape: Место
# =============================================================

vez:МестоShape a sh:NodeShape ;
    sh:targetClass vez:Место ;
    sh:property [
        sh:path vez:placeName ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "place name" ;
    ] .

# =============================================================
# Shape: Наречје
# =============================================================

vez:НаречјеShape a sh:NodeShape ;
    sh:targetClass vez:Наречје ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:name "preferred label" ;
    ] ;
    sh:property [
        sh:path vez:hasGroup ;
        sh:minCount 1 ;
        sh:class vez:ДијалектнаГрупа ;
        sh:name "dialect groups" ;
    ] .

# =============================================================
# Shape: Дијалект
# =============================================================

vez:ДијалектShape a sh:NodeShape ;
    sh:targetClass vez:Дијалект ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:name "preferred label" ;
    ] ;
    sh:property [
        sh:path skos:broader ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "parent group" ;
    ] .
