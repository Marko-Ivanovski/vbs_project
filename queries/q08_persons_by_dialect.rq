# Q8: Кои лица се споменати и во кои дијалекти?
# People mentioned and in which dialects.

PREFIX vez: <http://example.org/vezilka/ontology#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT ?personName ?dialectLabel (COUNT(?seg) AS ?mentions)
WHERE {
    ?seg a vez:ТекстуаленСегмент ;
         vez:inDialect ?dialect ;
         vez:mentionsPerson ?person .
    ?person vez:personName ?personName .
    ?dialect skos:prefLabel ?dialectLabel .
    FILTER(LANG(?dialectLabel) = "mk")
}
GROUP BY ?personName ?dialectLabel
ORDER BY DESC(?mentions)
LIMIT 30
