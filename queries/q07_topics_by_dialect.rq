# Q7: Кои теми се застапени по дијалект?
# Topics covered per dialect (requires topic classification data).

PREFIX vez: <https://w3id.org/vezilka/ontology#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT ?dialectLabel ?topicLabel (COUNT(?seg) AS ?segmentCount)
WHERE {
    ?seg a vez:ТекстуаленСегмент ;
         vez:inDialect ?dialect ;
         vez:hasTopic ?topic .
    ?dialect skos:prefLabel ?dialectLabel .
    ?topic skos:prefLabel ?topicLabel .
    FILTER(LANG(?dialectLabel) = "mk")
    FILTER(LANG(?topicLabel) = "mk")
}
GROUP BY ?dialectLabel ?topicLabel
ORDER BY ?dialectLabel DESC(?segmentCount)
