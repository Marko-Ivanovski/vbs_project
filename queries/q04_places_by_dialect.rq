# Q4: Кои места се споменати во текстовите од даден дијалект?
# Places mentioned in texts from a specific dialect.

PREFIX vez: <http://example.org/vezilka/ontology#>
PREFIX vezr: <http://example.org/vezilka/resource/>

SELECT ?placeName (COUNT(?seg) AS ?mentions)
WHERE {
    ?seg a vez:ТекстуаленСегмент ;
         vez:inDialect vezr:bitolski ;
         vez:mentionsPlace ?place .
    ?place vez:placeName ?placeName .
}
GROUP BY ?placeName
ORDER BY DESC(?mentions)
