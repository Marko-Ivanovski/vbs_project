# Q10: Кои фрази се уникатни за одреден дијалект?
# Phrases unique to a specific dialect (requires phrase extraction data).

PREFIX vez: <https://w3id.org/vezilka/ontology#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

SELECT ?phraseText ?dialectLabel
WHERE {
    ?phrase a vez:Фраза ;
            vez:phraseText ?phraseText ;
            vez:phraseInDialect ?dialect .
    ?dialect skos:prefLabel ?dialectLabel .
    FILTER(LANG(?dialectLabel) = "mk")
    FILTER NOT EXISTS {
        ?phrase vez:phraseInDialect ?otherDialect .
        FILTER(?otherDialect != ?dialect)
    }
}
ORDER BY ?dialectLabel
LIMIT 30
