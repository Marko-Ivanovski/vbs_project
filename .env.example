# Neo4j Aura connection — copy this file to `.env` and fill in your values.
# Get these from the AuraDB console when you create a free instance
# (the connection URI + the password shown ONCE at creation, also in the
# downloaded credentials .txt file).

NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here
